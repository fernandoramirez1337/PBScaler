# ─────────────────────────────────────────────────────────────────────
# GKE experiment cluster — shared configuration
# Source this file from setup_gke.sh and teardown_gke.sh
# ─────────────────────────────────────────────────────────────────────

# ⚠  YOU MUST SET THIS before running any script
PROJECT_ID="tesis-pbscaler"

# Cluster
CLUSTER_NAME="pbscaler-experiment"
ZONE="us-central1-a"
MACHINE_TYPE="e2-standard-4"
NUM_NODES=3
CLUSTER_VERSION="1.29"          # GKE release channel will pick the latest patch

# Istio
ISTIO_VERSION="1.24.3"

# Namespaces
APP_NAMESPACE="online-boutique"
MON_NAMESPACE="monitoring"

# Helm release name for kube-prometheus-stack
PROM_RELEASE="prometheus-stack"

# Paths (relative to project root)
BOUTIQUE_MANIFESTS="benchmarks/microservices-demo/kubernetes-manifests"
ISTIO_MANIFESTS="benchmarks/microservices-demo/istio-manifests"
