# ─────────────────────────────────────────────────────────────────────
# Train Ticket experiment cluster — shared configuration
# Sourced by setup_train_ticket.sh, teardown_train_ticket.sh,
# run_pbscaler_train_ticket.sh
#
# Train Ticket is significantly heavier than Online Boutique:
#   - 41 Java/Spring Boot microservices (vs. 11 for OB)
#   - Each Spring service ≈ 200-400 MB resident
#   - Cold start 30-90 s per service (vs. <5 s for OB Go)
# Hence: bigger nodes (16 GB / 4 vCPU) and one more node.
# ─────────────────────────────────────────────────────────────────────

# ⚠  YOU MUST SET THIS before running any script
# Should match PROJECT_ID in scripts/gke.env if reusing the same GCP project.
PROJECT_ID="pbscaler-01"

# Cluster
CLUSTER_NAME="pbscaler-train-ticket"
ZONE="us-central1-a"
# Originally n2-standard-4 to get the n2 perf class, but us-central1-a hit
# GCE_STOCKOUT for n2 on 2026-04-29. e2-standard-4 has the same shape
# (4 vCPU / 16 GB) and much higher zone availability; perf delta is small
# and irrelevant for failure-mode validation. n2 was a cost-perf preference,
# not a correctness requirement.
MACHINE_TYPE="e2-standard-4"     # 4 vCPU / 16 GB RAM
NUM_NODES=3                      # 3 × 4 vCPU = 12 = default GCP quota CPUS_ALL_REGIONS
                                 # 3 × 16 GB = 48 GB — tight for 41 Java pods,
                                 # may OOM-kill some services. To run with 4 nodes
                                 # (64 GB headroom) request a quota increase first.
CLUSTER_VERSION="1.29"

# Istio
ISTIO_VERSION="1.24.3"

# Namespaces
APP_NAMESPACE="train-ticket"
MON_NAMESPACE="monitoring"

# Helm release name for kube-prometheus-stack
PROM_RELEASE="prometheus-stack"

# Paths (relative to project root)
TT_MANIFESTS="benchmarks/train-ticket/deployment/kubernetes-manifests/quickstart-k8s"
