# ─────────────────────────────────────────────────────────────────────
# DigitalOcean Kubernetes (DOKS) — Train Ticket experiment cluster
# Sourced by setup_doks_train_ticket.sh, teardown_doks_train_ticket.sh,
# run_pbscaler_doks_train_ticket.sh
#
# Why DOKS for Train Ticket:
#   GCP `pbscaler-01` capped at CPUS_ALL_REGIONS=12 with a hard "no quota
#   increase available" because the project lacks usage history. DOKS does
#   not apply usage-history caps. Plan_CLAUDE_CODE.md sec 8 already
#   contemplated DO as the TT cloud target.
#
# Cluster sizing matches the GCP TT plan: 4 nodes × 4 vCPU × 8-16 GB,
# enough headroom for 41 Java + Istio sidecars (~25 vCPU requested).
# ─────────────────────────────────────────────────────────────────────

# Cluster
CLUSTER_NAME="pbscaler-train-ticket"
REGION="nyc1"
# Droplet limit raised to 10 by DO support 2026-05-04. Use 6 nodes:
#   6 × s-4vcpu-8gb = 24 vCPU / 48 GB total
# This matches what the original GCP plan called for (4× n2-standard-4),
# and gives ~headroom for system pods (kube-proxy, DNS, kubelet, Istio
# control plane) on top of the 41 TT Spring Boot pods + sidecars
# (~25 vCPU requested aggregate). s-8vcpu-16gb is not a valid DOKS slug.
NODE_SIZE="s-4vcpu-8gb"
NODE_COUNT=6
K8S_VERSION="1.33.9-do.5"   # `doctl k8s options versions` for current list

# Istio
ISTIO_VERSION="1.24.3"

# Namespaces
APP_NAMESPACE="train-ticket"
MON_NAMESPACE="monitoring"

# Helm release name for kube-prometheus-stack
PROM_RELEASE="prometheus-stack"

# Paths (relative to project root)
TT_MANIFESTS="benchmarks/train-ticket/deployment/kubernetes-manifests/quickstart-k8s"

# Cost estimate (NYC region, 2026 pricing)
#   6 × s-4vcpu-8gb @ $0.072/hr = $0.43/hr
#   Smoke deploy (~30 min): ~$0.22
#   6 runs (step×3 + bursty×3 = 3 h): ~$1.30
#   Calibración + buffer: ~$1
#   Total Sprint 1B TT: ~$3-4 (de $200 student credit)
